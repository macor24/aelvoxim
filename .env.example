# Aelvoxim environment variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will not be committed.

# LLM Provider (required)
# Example values can be found in docs/llm_setup.md
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...

# Bing Search API (optional — enables official API search instead of HTML scraping)
# METACORE_BING_API_KEY=your_key_here

# PostgreSQL (required for production — JSON file fallback used if unset)
AELVOXIM_DATABASE_URL=host=localhost port=5432 dbname=aelvoxim user=aelvoxim password=change_me

# Windows-MCP (optional — desktop control via MCP protocol)
# WINDOWS_MCP_KEY=sk-aelvoxim-...
# WINDOWS_MCP_URL=http://172.24.80.1:8000

# CORS allowed origins (comma-separated, no spaces)
# AELVOXIM_CORS_ORIGINS=http://localhost:3000,http://localhost:9702

# License secret (required for license key verification)
# AELVOXIM_LICENSE_SECRET=your_hmac_secret_here

# Admin API key (overrides normal auth for admin endpoints)
# AELVOXIM_ADMIN_KEY=sk-admin-...

# WeCom (企业微信) — optional notification bot
# See docs/wecom.md for setup instructions
# WECOM_CORP_ID=
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=
# WECOM_AGENT_ID=
# WECOM_SECRET=
