# Aelvoxim environment variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will not be committed.

# LLM Provider (required)
# Example values can be found in docs/llm_setup.md
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...

# Bing Search API (optional — enables official API search instead of HTML scraping)
# METACORE_BING_API_KEY=your_key_here

# PostgreSQL (optional — persistent storage backend)
# PGHOST=localhost
# PGUSER=aelvoxim
# PGPASSWORD=your_password
# PGDATABASE=aelvoxim

# WeCom (企业微信) — optional notification bot
# See docs/wecom.md for setup instructions
# WECOM_CORP_ID=
# WECOM_TOKEN=
# WECOM_ENCODING_AES_KEY=
# WECOM_AGENT_ID=
# WECOM_SECRET=
