# Aelvoxim environment variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will not be committed.

# WeChat Work (WeCom) credentials (optional, for notification bot)
WECOM_CORP_ID=your_corp_id_here
WECOM_TOKEN=your_token_here
WECOM_ENCODING_AES_KEY=your_encoding_aes_key_here
WECOM_AGENT_ID=1000002
WECOM_SECRET=your_secret_here
